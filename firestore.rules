rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Messages collection rules
    match /messages/{messageId} {
      // Free public submission for contact inquiries with total schema audit
      allow create: if isValidMessage(incoming()) 
                     && isValidId(messageId);

      // Only backend admin role allowed to read/update/delete submissions
      allow read, update, delete: if isAdmin();
    }

    // Helper Functions
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Direct privilege boost for the verified primary owner account OR fallback DB document check
      return isSignedIn() && (
        (request.auth.token.email == 'sauvikd68@gmail.com' && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'timestamp', 'sourceWebsite', 'status', 'browserInfo'])
        && data.keys().size() == 7
        && data.name is string && data.name.size() > 0 && data.name.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.message is string && data.message.size() > 0 && data.message.size() <= 4096
        && data.status is string && (data.status == 'unread' || data.status == 'read')
        && data.sourceWebsite is string && data.sourceWebsite == 'sauvikdev.in'
        && data.browserInfo is string && data.browserInfo.size() <= 2048
        && data.timestamp == request.time;
    }
  }
}
